{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "google_auth": false,
  "agents": {
    // Main orchestrator — plans, delegates to specialists, drives parallel execution
    "sisyphus": {
      "model": "opencode/claude-sonnet-4-6"
    },
    // Deep worker — architecture reasoning, complex multi-file debugging (80.2% SWE-bench free model)
    "hephaestus": {
      "model": "opencode/minimax-m2.5-free"
    },
    // Read-only consultant — architecture advice and debugging guidance, no code changes
    "oracle": {
      "model": "opencode/qwen3.6-plus-free"
    },
    // Fast codebase search — pattern discovery, speed-focused
    "explore": {
      "model": "opencode/qwen3.6-plus-free"
    },
    // Vision/screenshot analysis — interprets UI, diagrams, visual content
    "multimodal-looker": {
      "model": "opencode/qwen3.6-plus-free"
    },
    // Strategic planner — interviews you like an engineer, identifies scope and ambiguities (Tab to activate)
    "prometheus": {
      "model": "opencode/claude-opus-4-6",
      "variant": "max"
    },
    // Gap analyzer — catches oversights and edge cases before plan finalization
    "metis": {
      "model": "opencode/claude-opus-4-6",
      "variant": "max"
    },
    // Plan reviewer — validates plans against clarity, verification, and context criteria
    "momus": {
      "model": "opencode/claude-sonnet-4-6"
    },
    // Execution conductor — distributes tasks from Prometheus plans to specialized subagents
    "atlas": {
      "model": "opencode/qwen3.6-plus-free"
    },
    // Lighter orchestrator — handles simpler tasks without full Sisyphus overhead
    "sisyphus-junior": {
      "model": "opencode/qwen3.6-plus-free"
    }
  },
  "categories": {
    // Frontend, UI/UX, and design work — Gemini excels at visual tasks
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high"
    },
    // Hard logic, architecture decisions, complex reasoning
    "ultrabrain": {
      "model": "opencode/claude-sonnet-4-6"
    },
    // Autonomous research and extended execution (80.2% SWE-bench free model)
    "deep": {
      "model": "opencode/minimax-m2.5-free"
    },
    // Creative and design tasks — Gemini suited for artistry
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high"
    },
    // Single-file changes, typos, minor fixes — speed over depth
    "quick": {
      "model": "opencode/minimax-m2.5-free"
    },
    // General simple work — low priority tasks
    "unspecified-low": {
      "model": "opencode/qwen3.6-plus-free"
    },
    // General complex work — quality fallback
    "unspecified-high": {
      "model": "opencode/claude-sonnet-4-6"
    },
    // Documentation, text generation, prose
    "writing": {
      "model": "opencode/qwen3.6-plus-free"
    }
  }
}
